<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Detent.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#121212</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Detent</item>
    </style>

    <style name="Theme.Detent" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        AppCompat theme used exclusively for OssLicensesMenuActivity, which extends
        AppCompatActivity and cannot accept a Material3 theme.
    -->
    <style name="Theme.Detent.OssLicenses" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/burnt_orange</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/burnt_orange</item>
    </style>
</resources>